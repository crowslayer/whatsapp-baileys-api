# Copiar a .env y ajustar valores (no commitear .env con secretos reales).

# Runtime (NODE_ENV obligatorio: development | production | test | staging)
NODE_ENV=development
PORT=3333
API_PATH=api
API_VERSION=v1
APP_URL=http://localhost:3333

# Base de datos (este repo usa Mongoose en la práctica)
DB_TYPE=mongoose
DB_ENABLED=true
DB_URI=mongodb://localhost:27017/whatsapp-api

# Seguridad: jwt | oauth2
SECURITY_TYPE=jwt
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d

# Si SECURITY_TYPE=oauth2, descomentar y rellenar:
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_AUTH_SERVER=

# CORS (coma-separado). En production es obligatorio.
ACCEPTED_ORIGINS=http://localhost:3000,http://localhost:4200

# Opcionales (string "true" | "false")
PROTECT_ROUTES=false
ENABLED_RATE_LIMITS=false
