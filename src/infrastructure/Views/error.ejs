<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - WhatsApp API</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 500px;
            width: 100%;
            padding: 40px;
            text-align: center;
        }

        .error-icon {
            font-size: 80px;
            margin-bottom: 20px;
        }

        h1 {
            color: #DC3545;
            margin-bottom: 10px;
        }

        p {
            color: #666;
            line-height: 1.6;
            margin: 10px 0;
        }

        .error-details {
            background: #F8D7DA;
            border-left: 4px solid #DC3545;
            padding: 15px;
            border-radius: 5px;
            margin: 20px 0;
            text-align: left;
        }

        .back-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 20px;
            text-decoration: none;
            display: inline-block;
        }

        .back-btn:hover {
            background: #5568d3;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="error-icon">❌</div>
        <h1>Oops! Algo salió mal</h1>
        <p><%= message %></p>
        
        <% if (typeof error !== 'undefined') { %>
        <div class="error-details">
            <strong>Detalles:</strong>
            <p><%= error %></p>
        </div>
        <% } %>

        <% if (typeof instanceId !== 'undefined') { %>
        <p>Instance ID: <code><%= instanceId %></code></p>
        <% } %>

        <a href="/" class="back-btn">← Volver al inicio</a>
    </div>
</body>
</html>