{
  "name": "whatsapp-baileys-api",
  "version": "1.0.0",
  "description": "WhatsApp Multi-Instance API with Baileys",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json -f -fe .js && pnpm run build:di",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "validate": "pnpm run type-check && pnpm run lint && pnpm run format:check",
    "build:di": "copyfiles -u 1 \"src/**/*.{json,yaml,html,png}\" dist/"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "api",
    "nodejs"
  ],
  "author": "Alexander Herrera <crowslayer@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "axios": "^1.13.4",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ejs": "^4.0.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "libphonenumber-js": "^1.12.41",
    "mongoose": "^8.22.1",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-dependency-injection": "^3.2.6",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    ".enveslint": "link:.enveslint",
    "@express-rate-limit/tsconfig": "^1.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.32",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^3.0.6",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
